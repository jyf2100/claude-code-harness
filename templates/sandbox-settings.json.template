{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Sandbox 设置模板 - 在最小化对操作感影响的同时强化安全性",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker",
      "docker-compose",
      "watchman",
      "systemctl",
      "launchctl",
      "brew services"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "api.anthropic.com",
        "pypi.org",
        "rubygems.org",
        "crates.io"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip *)"
    ]
  },
  "_notes": {
    "purpose": "基于 Claude Code Permissions 文档的推荐 Sandbox 设置",
    "autoAllowBashIfSandboxed": "设置为 true 以最小化 Sandbox 启用时的许可提示",
    "excludedCommands": "需要在 Sandbox 外执行的命令（需要访问主机系统）",
    "allowedDomains": "允许开发所需的外部服务的网络访问"
  }
}
