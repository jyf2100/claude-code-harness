{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "Sandbox 設定テンプレート - 操作感への影響を最小化しつつセキュリティを強化",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker",
      "docker-compose",
      "watchman",
      "systemctl",
      "launchctl",
      "brew services"
    ],
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "raw.githubusercontent.com",
        "registry.npmjs.org",
        "api.anthropic.com",
        "pypi.org",
        "rubygems.org",
        "crates.io"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pip *)"
    ]
  },
  "_notes": {
    "purpose": "Claude Code Permissions ドキュメントに基づく推奨 Sandbox 設定",
    "autoAllowBashIfSandboxed": "true にすることで Sandbox 有効時の許可プロンプトを最小化",
    "excludedCommands": "Sandbox 外で実行が必要なコマンド（ホストシステムへのアクセスが必要）",
    "allowedDomains": "開発に必要な外部サービスへのネットワークアクセスを許可"
  }
}
