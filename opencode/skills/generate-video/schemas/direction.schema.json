{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/direction.schema.json",
  "title": "Direction Schema",
  "description": "演出系统的架构。定义每个场景的演出参数（过渡、强调、背景、时间）。",
  "version": "1.0.0",
  "type": "object",
  "required": ["scene_id", "transition", "emphasis", "background", "timing"],
  "properties": {
    "scene_id": {
      "type": "string",
      "description": "目标场景的ID（必须与场景中的ID一致）",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "transition": {
      "type": "object",
      "description": "此场景的过渡设置",
      "required": ["type", "duration_ms"],
      "properties": {
        "type": {
          "type": "string",
          "description": "过渡类型",
          "enum": ["fade", "slide_in", "zoom", "cut"]
        },
        "duration_ms": {
          "type": "integer",
          "description": "过渡时长（毫秒）",
          "minimum": 0,
          "maximum": 2000,
          "default": 500
        },
        "easing": {
          "type": "string",
          "description": "缓动函数",
          "enum": ["linear", "easeIn", "easeOut", "easeInOut"],
          "default": "easeInOut"
        },
        "direction": {
          "type": "string",
          "description": "滑动方向（仅slide_in时）",
          "enum": ["left", "right", "top", "bottom"],
          "default": "right"
        }
      },
      "additionalProperties": false
    },
    "emphasis": {
      "type": "object",
      "description": "场景内的强调表现",
      "required": ["level"],
      "properties": {
        "level": {
          "type": "string",
          "description": "强调级别",
          "enum": ["high", "medium", "low"]
        },
        "text": {
          "type": "array",
          "description": "强调的文本元素（关键词/短语）",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "sound": {
          "type": "string",
          "description": "效果音类型",
          "enum": ["none", "pop", "whoosh", "chime", "ding"],
          "default": "none"
        },
        "color": {
          "type": "string",
          "description": "强调色（HEX格式）",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#00F5FF"
        },
        "position": {
          "type": "string",
          "description": "强调元素的布局",
          "enum": ["center", "top", "bottom", "left", "right"],
          "default": "center"
        }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "description": "背景设置",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "description": "背景类型",
          "enum": ["cyberpunk", "corporate", "minimal", "gradient", "particles"]
        },
        "primary_color": {
          "type": "string",
          "description": "主色（HEX格式）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "secondary_color": {
          "type": "string",
          "description": "次色（HEX格式）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "opacity": {
          "type": "number",
          "description": "背景不透明度",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        },
        "blur": {
          "type": "boolean",
          "description": "是否对背景应用模糊",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "timing": {
      "type": "object",
      "description": "场景内的时间调整",
      "properties": {
        "delay_before_ms": {
          "type": "integer",
          "description": "场景开始前的等待时间（毫秒）",
          "minimum": 0,
          "default": 0
        },
        "delay_after_ms": {
          "type": "integer",
          "description": "场景结束后的等待时间（毫秒）",
          "minimum": 0,
          "default": 0
        },
        "audio_start_offset_ms": {
          "type": "integer",
          "description": "音频开始偏移（毫秒，正=延迟，负=提前）",
          "default": 1000
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
