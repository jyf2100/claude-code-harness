{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/animation.schema.json",
  "title": "Animation Schema",
  "description": "动画设置的架构。定义过渡、缓动、弹簧物理参数。",
  "version": "1.0.0",
  "type": "object",
  "required": ["type", "duration_ms"],
  "properties": {
    "type": {
      "type": "string",
      "description": "动画类型",
      "enum": ["fade", "slide_in", "zoom", "cut", "spring", "rotate", "scale"]
    },
    "duration_ms": {
      "type": "integer",
      "description": "动画时长（毫秒）",
      "minimum": 0,
      "maximum": 10000
    },
    "easing": {
      "type": "string",
      "description": "缓动函数（spring类型时忽略）",
      "enum": ["linear", "easeIn", "easeOut", "easeInOut", "easeInQuad", "easeOutQuad", "easeInOutQuad", "easeInCubic", "easeOutCubic", "easeInOutCubic"],
      "default": "easeInOut"
    },
    "spring": {
      "type": "object",
      "description": "弹簧物理参数（仅type为spring时适用）",
      "properties": {
        "damping": {
          "type": "number",
          "description": "阻尼（衰减系数）。值越大停止越快",
          "minimum": 1,
          "maximum": 500,
          "default": 200
        },
        "stiffness": {
          "type": "number",
          "description": "刚度（弹簧硬度）。值越大反弹越强",
          "minimum": 1,
          "maximum": 500,
          "default": 100
        },
        "mass": {
          "type": "number",
          "description": "质量。值越大动作越重",
          "minimum": 0.1,
          "maximum": 10,
          "default": 1
        },
        "overshoot_clamping": {
          "type": "boolean",
          "description": "是否抑制过冲（超出）",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "delay_ms": {
      "type": "integer",
      "description": "动画开始前的延迟（毫秒）",
      "minimum": 0,
      "default": 0
    },
    "from": {
      "type": "object",
      "description": "动画开始时的值",
      "properties": {
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "x": {
          "type": "number",
          "description": "X坐标偏移（像素）"
        },
        "y": {
          "type": "number",
          "description": "Y坐标偏移（像素）"
        },
        "scale": {
          "type": "number",
          "description": "缩放值",
          "minimum": 0
        },
        "rotate": {
          "type": "number",
          "description": "旋转角度（度）"
        }
      },
      "additionalProperties": false
    },
    "to": {
      "type": "object",
      "description": "动画结束时的值",
      "properties": {
        "opacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "x": {
          "type": "number",
          "description": "X坐标偏移（像素）"
        },
        "y": {
          "type": "number",
          "description": "Y坐标偏移（像素）"
        },
        "scale": {
          "type": "number",
          "description": "缩放值",
          "minimum": 0
        },
        "rotate": {
          "type": "number",
          "description": "旋转角度（度）"
        }
      },
      "additionalProperties": false
    },
    "interpolate": {
      "type": "object",
      "description": "Remotion interpolate函数的详细设置",
      "properties": {
        "input_range": {
          "type": "array",
          "description": "输入范围（帧数数组）",
          "items": {
            "type": "number"
          },
          "minItems": 2
        },
        "output_range": {
          "type": "array",
          "description": "输出范围（值数组）",
          "items": {
            "type": "number"
          },
          "minItems": 2
        },
        "extrapolate_left": {
          "type": "string",
          "description": "范围外（左）的外推方法",
          "enum": ["clamp", "extend", "identity"],
          "default": "clamp"
        },
        "extrapolate_right": {
          "type": "string",
          "description": "范围外（右）的外推方法",
          "enum": ["clamp", "extend", "identity"],
          "default": "clamp"
        }
      },
      "additionalProperties": false
    },
    "loop": {
      "type": "object",
      "description": "循环设置（可选）",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "是否启用循环",
          "default": false
        },
        "count": {
          "type": "integer",
          "description": "循环次数（0为无限循环）",
          "minimum": 0,
          "default": 0
        },
        "reverse": {
          "type": "boolean",
          "description": "是否往返循环（前进→后退）",
          "default": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
