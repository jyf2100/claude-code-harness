{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/emphasis.schema.json",
  "title": "Emphasis Schema",
  "description": "强调表现的架构。定义文本强调、效果音、颜色、布局。",
  "version": "1.0.0",
  "type": "object",
  "required": ["level"],
  "properties": {
    "level": {
      "type": "string",
      "description": "强调级别",
      "enum": ["high", "medium", "low"]
    },
    "text": {
      "type": "array",
      "description": "强调的文本元素（关键词/短语）",
      "items": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": {
            "type": "string",
            "description": "强调的文本内容"
          },
          "start_ms": {
            "type": "integer",
            "description": "强调开始时间（场景内相对位置，毫秒）",
            "minimum": 0
          },
          "duration_ms": {
            "type": "integer",
            "description": "强调显示时长（毫秒）",
            "minimum": 1,
            "default": 1000
          },
          "style": {
            "type": "string",
            "description": "文本样式",
            "enum": ["bold", "glitch", "underline", "highlight", "glow"],
            "default": "bold"
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "sound": {
      "type": "object",
      "description": "效果音设置",
      "properties": {
        "type": {
          "type": "string",
          "description": "效果音类型",
          "enum": ["none", "pop", "whoosh", "chime", "ding"],
          "default": "none"
        },
        "volume": {
          "type": "number",
          "description": "音量（0.0-1.0）",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5
        },
        "timing": {
          "type": "string",
          "description": "效果音的时机",
          "enum": ["start", "end", "peak"],
          "default": "start"
        },
        "trigger_ms": {
          "type": "integer",
          "description": "效果音触发时间（场景内相对位置，毫秒）",
          "minimum": 0,
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "color": {
      "type": "object",
      "description": "强调色设置",
      "properties": {
        "primary": {
          "type": "string",
          "description": "主色（HEX格式）",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#00F5FF"
        },
        "secondary": {
          "type": "string",
          "description": "次色（HEX格式，用于渐变）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "glow": {
          "type": "boolean",
          "description": "是否应用发光效果",
          "default": true
        },
        "glow_intensity": {
          "type": "number",
          "description": "发光强度（模糊半径，像素）",
          "minimum": 0,
          "maximum": 100,
          "default": 20
        }
      },
      "additionalProperties": false
    },
    "position": {
      "type": "object",
      "description": "强调元素的布局设置",
      "properties": {
        "alignment": {
          "type": "string",
          "description": "布局位置",
          "enum": ["center", "top", "bottom", "left", "right", "top_left", "top_right", "bottom_left", "bottom_right"],
          "default": "center"
        },
        "offset": {
          "type": "object",
          "description": "布局偏移（像素）",
          "properties": {
            "x": {
              "type": "number",
              "description": "X轴偏移",
              "default": 0
            },
            "y": {
              "type": "number",
              "description": "Y轴偏移",
              "default": 0
            }
          },
          "additionalProperties": false
        },
        "padding": {
          "type": "number",
          "description": "距离屏幕边缘的间距（像素）",
          "minimum": 0,
          "default": 40
        }
      },
      "additionalProperties": false
    },
    "animation": {
      "type": "object",
      "description": "强调显示的动画设置",
      "properties": {
        "entry": {
          "type": "string",
          "description": "入场动画",
          "enum": ["none", "fade_in", "slide_in", "zoom_in", "bounce"],
          "default": "fade_in"
        },
        "exit": {
          "type": "string",
          "description": "退场动画",
          "enum": ["none", "fade_out", "slide_out", "zoom_out"],
          "default": "fade_out"
        },
        "duration_ms": {
          "type": "integer",
          "description": "动画时长（毫秒）",
          "minimum": 1,
          "maximum": 2000,
          "default": 500
        },
        "pulse": {
          "type": "boolean",
          "description": "是否启用脉冲效果（闪烁/缩放）",
          "default": false
        },
        "pulse_speed": {
          "type": "number",
          "description": "脉冲速度（每秒周期数）",
          "minimum": 0.1,
          "maximum": 10,
          "default": 1.0
        }
      },
      "additionalProperties": false
    },
    "background": {
      "type": "object",
      "description": "强调元素的背景设置（如框显示）",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "是否显示背景",
          "default": false
        },
        "color": {
          "type": "string",
          "description": "背景色（HEX格式或RGBA）",
          "default": "rgba(0, 0, 0, 0.8)"
        },
        "border_radius": {
          "type": "number",
          "description": "圆角半径（像素）",
          "minimum": 0,
          "default": 8
        },
        "padding": {
          "type": "object",
          "description": "背景内的内边距（像素）",
          "properties": {
            "top": {
              "type": "number",
              "minimum": 0,
              "default": 16
            },
            "right": {
              "type": "number",
              "minimum": 0,
              "default": 32
            },
            "bottom": {
              "type": "number",
              "minimum": 0,
              "default": 16
            },
            "left": {
              "type": "number",
              "minimum": 0,
              "default": 32
            }
          },
          "additionalProperties": false
        },
        "border": {
          "type": "object",
          "description": "边框设置",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "width": {
              "type": "number",
              "minimum": 0,
              "default": 2
            },
            "color": {
              "type": "string",
              "description": "边框颜色（HEX格式）",
              "pattern": "^#[0-9A-Fa-f]{6}$",
              "default": "#00F5FF"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "typography": {
      "type": "object",
      "description": "排版设置",
      "properties": {
        "font_size": {
          "type": "number",
          "description": "字体大小（像素）",
          "minimum": 12,
          "maximum": 200,
          "default": 48
        },
        "font_weight": {
          "type": ["string", "number"],
          "description": "字体粗细",
          "enum": [100, 200, 300, 400, 500, 600, 700, 800, 900, "normal", "bold"],
          "default": 700
        },
        "font_family": {
          "type": "string",
          "description": "字体系列",
          "default": "sans-serif"
        },
        "line_height": {
          "type": "number",
          "description": "行高（倍数）",
          "minimum": 0.5,
          "maximum": 3,
          "default": 1.5
        },
        "letter_spacing": {
          "type": "number",
          "description": "字母间距（像素）",
          "default": 0
        },
        "text_transform": {
          "type": "string",
          "description": "文本转换",
          "enum": ["none", "uppercase", "lowercase", "capitalize"],
          "default": "none"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
