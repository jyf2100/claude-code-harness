{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-code-harness.com/schemas/visual-patterns.schema.json",
  "title": "Visual Patterns Schema",
  "description": "图像生成模式的架构。定义比较图、概念图、流程图、强调图4种模式。",
  "version": "1.0.0",
  "type": "object",
  "required": ["type", "topic"],
  "properties": {
    "type": {
      "type": "string",
      "description": "图像模式类型",
      "enum": ["comparison", "concept", "flow", "highlight"]
    },
    "topic": {
      "type": "string",
      "description": "图像的主题/题材",
      "minLength": 1,
      "maxLength": 200
    },
    "style": {
      "type": "string",
      "description": "视觉风格（可选）",
      "enum": ["minimalist", "technical", "modern", "gradient", "flat", "3d"],
      "default": "modern"
    },
    "color_scheme": {
      "type": "object",
      "description": "配色方案设置",
      "properties": {
        "primary": {
          "type": "string",
          "description": "主色（例: #3B82F6）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "secondary": {
          "type": "string",
          "description": "次色（例: #10B981）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "accent": {
          "type": "string",
          "description": "强调色（例: #F59E0B）",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "background": {
          "type": "string",
          "description": "背景色（例: #1F2937）",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "default": "#1F2937"
        }
      },
      "additionalProperties": false
    },
    "comparison": {
      "type": "object",
      "description": "comparison（比较图）模式设置",
      "required": ["left_side", "right_side"],
      "properties": {
        "left_side": {
          "type": "object",
          "description": "左侧（Before / 反例）",
          "required": ["label", "items"],
          "properties": {
            "label": {
              "type": "string",
              "description": "标签（例: Before, 反例）",
              "minLength": 1,
              "maxLength": 50
            },
            "items": {
              "type": "array",
              "description": "显示项目列表",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "minItems": 1,
              "maxItems": 5
            },
            "icon": {
              "type": "string",
              "description": "图标类型（例: x, warning, sad）",
              "enum": ["x", "warning", "sad", "slow", "confused", "broken"]
            },
            "sentiment": {
              "type": "string",
              "description": "情感/印象",
              "enum": ["negative", "neutral", "caution"],
              "default": "negative"
            }
          },
          "additionalProperties": false
        },
        "right_side": {
          "type": "object",
          "description": "右侧（After / 正例）",
          "required": ["label", "items"],
          "properties": {
            "label": {
              "type": "string",
              "description": "标签（例: After, 正例）",
              "minLength": 1,
              "maxLength": 50
            },
            "items": {
              "type": "array",
              "description": "显示项目列表",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 100
              },
              "minItems": 1,
              "maxItems": 5
            },
            "icon": {
              "type": "string",
              "description": "图标类型（例: check, star, happy）",
              "enum": ["check", "star", "happy", "fast", "clear", "solid"]
            },
            "sentiment": {
              "type": "string",
              "description": "情感/印象",
              "enum": ["positive", "neutral", "success"],
              "default": "positive"
            }
          },
          "additionalProperties": false
        },
        "divider": {
          "type": "string",
          "description": "分隔线类型",
          "enum": ["arrow", "vs", "line", "gradient"],
          "default": "arrow"
        }
      },
      "additionalProperties": false
    },
    "concept": {
      "type": "object",
      "description": "concept（概念图）模式设置",
      "required": ["elements"],
      "properties": {
        "elements": {
          "type": "array",
          "description": "概念元素列表",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": {
                "type": "string",
                "description": "元素的唯一ID",
                "pattern": "^[a-z0-9_-]+$"
              },
              "label": {
                "type": "string",
                "description": "元素的标签",
                "minLength": 1,
                "maxLength": 50
              },
              "description": {
                "type": "string",
                "description": "元素的说明（可选）",
                "maxLength": 200
              },
              "level": {
                "type": "integer",
                "description": "层级（0=最顶层）",
                "minimum": 0,
                "maximum": 5,
                "default": 0
              },
              "parent_id": {
                "type": "string",
                "description": "父元素ID（表示层级结构）",
                "pattern": "^[a-z0-9_-]+$"
              },
              "icon": {
                "type": "string",
                "description": "图标类型",
                "enum": ["box", "circle", "diamond", "hexagon", "cloud", "gear", "database", "server", "user", "code"]
              },
              "emphasis": {
                "type": "string",
                "description": "强调度",
                "enum": ["high", "medium", "low"],
                "default": "medium"
              }
            },
            "additionalProperties": false
          },
          "minItems": 2,
          "maxItems": 10
        },
        "relationships": {
          "type": "array",
          "description": "元素之间的关系",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {
                "type": "string",
                "description": "关系起点的元素ID",
                "pattern": "^[a-z0-9_-]+$"
              },
              "to": {
                "type": "string",
                "description": "关系终点的元素ID",
                "pattern": "^[a-z0-9_-]+$"
              },
              "label": {
                "type": "string",
                "description": "关系标签（例: 包含、生成、依赖）",
                "maxLength": 30
              },
              "type": {
                "type": "string",
                "description": "关系类型",
                "enum": ["hierarchy", "flow", "dependency", "association"],
                "default": "association"
              },
              "bidirectional": {
                "type": "boolean",
                "description": "是否为双向关系",
                "default": false
              }
            },
            "additionalProperties": false
          }
        },
        "layout": {
          "type": "string",
          "description": "布局类型",
          "enum": ["hierarchy", "radial", "grid", "flow", "circular"],
          "default": "hierarchy"
        }
      },
      "additionalProperties": false
    },
    "flow": {
      "type": "object",
      "description": "flow（流程图）模式设置",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "description": "流程步骤",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": {
                "type": "string",
                "description": "步骤的唯一ID",
                "pattern": "^[a-z0-9_-]+$"
              },
              "label": {
                "type": "string",
                "description": "步骤的标签",
                "minLength": 1,
                "maxLength": 50
              },
              "description": {
                "type": "string",
                "description": "步骤的详细说明",
                "maxLength": 150
              },
              "order": {
                "type": "integer",
                "description": "步骤顺序（从1开始）",
                "minimum": 1,
                "maximum": 20
              },
              "type": {
                "type": "string",
                "description": "步骤类型",
                "enum": ["start", "process", "decision", "end", "parallel", "subprocess"],
                "default": "process"
              },
              "icon": {
                "type": "string",
                "description": "图标类型",
                "enum": ["circle", "square", "diamond", "rounded", "hexagon"]
              },
              "duration": {
                "type": "string",
                "description": "所需时间估计（例: 2分钟、立即）",
                "maxLength": 20
              }
            },
            "additionalProperties": false
          },
          "minItems": 2,
          "maxItems": 10
        },
        "direction": {
          "type": "string",
          "description": "流程方向",
          "enum": ["horizontal", "vertical", "zigzag"],
          "default": "horizontal"
        },
        "arrow_style": {
          "type": "string",
          "description": "箭头样式",
          "enum": ["solid", "dashed", "dotted", "thick", "animated"],
          "default": "solid"
        },
        "show_numbers": {
          "type": "boolean",
          "description": "是否显示步骤编号",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "highlight": {
      "type": "object",
      "description": "highlight（强调）模式设置",
      "required": ["main_text"],
      "properties": {
        "main_text": {
          "type": "string",
          "description": "主文本（强调内容）",
          "minLength": 1,
          "maxLength": 100
        },
        "sub_text": {
          "type": "string",
          "description": "副文本（补充说明）",
          "maxLength": 150
        },
        "icon": {
          "type": "string",
          "description": "图标类型",
          "enum": ["star", "check", "alert", "info", "trophy", "rocket", "fire", "bolt", "heart", "none"],
          "default": "none"
        },
        "position": {
          "type": "string",
          "description": "文本布局",
          "enum": ["center", "top", "bottom", "left", "right"],
          "default": "center"
        },
        "effect": {
          "type": "string",
          "description": "视觉效果",
          "enum": ["glow", "shadow", "gradient", "outline", "none"],
          "default": "glow"
        },
        "font_size": {
          "type": "string",
          "description": "字体大小",
          "enum": ["small", "medium", "large", "xlarge"],
          "default": "large"
        },
        "emphasis": {
          "type": "string",
          "description": "强调度",
          "enum": ["high", "medium", "low"],
          "default": "high"
        }
      },
      "additionalProperties": false
    },
    "dimensions": {
      "type": "object",
      "description": "图像尺寸设置",
      "properties": {
        "width": {
          "type": "integer",
          "description": "宽度（像素）",
          "minimum": 256,
          "maximum": 2048,
          "default": 1920
        },
        "height": {
          "type": "integer",
          "description": "高度（像素）",
          "minimum": 256,
          "maximum": 2048,
          "default": 1080
        },
        "aspect_ratio": {
          "type": "string",
          "description": "宽高比",
          "enum": ["16:9", "4:3", "1:1", "9:16"],
          "default": "16:9"
        }
      },
      "additionalProperties": false
    },
    "generation": {
      "type": "object",
      "description": "生成设置",
      "properties": {
        "seed": {
          "type": "integer",
          "description": "确定性种子值（用于复现）",
          "minimum": 0
        },
        "quality": {
          "type": "string",
          "description": "图像质量",
          "enum": ["draft", "standard", "high"],
          "default": "standard"
        },
        "retries": {
          "type": "integer",
          "description": "质量不合格时的最大重试次数",
          "minimum": 0,
          "maximum": 5,
          "default": 3
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "description": "元数据（附加信息）",
      "properties": {
        "scene_id": {
          "type": "string",
          "description": "关联的场景ID"
        },
        "purpose": {
          "type": "string",
          "description": "图像用途（例: intro, demo, cta）",
          "maxLength": 50
        },
        "tags": {
          "type": "array",
          "description": "标签",
          "items": {
            "type": "string",
            "maxLength": 30
          },
          "maxItems": 10
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "oneOf": [
    {
      "properties": {
        "type": { "const": "comparison" }
      },
      "required": ["comparison"]
    },
    {
      "properties": {
        "type": { "const": "concept" }
      },
      "required": ["concept"]
    },
    {
      "properties": {
        "type": { "const": "flow" }
      },
      "required": ["flow"]
    },
    {
      "properties": {
        "type": { "const": "highlight" }
      },
      "required": ["highlight"]
    }
  ]
}
